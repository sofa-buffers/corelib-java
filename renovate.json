{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions bumps into one PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Group Maven plugin updates (compiler/surefire/jacoco/javadoc/exec) separately from test libs.",
      "matchManagers": ["maven"],
      "matchDepTypes": ["build"],
      "groupName": "maven plugins"
    },
    {
      "description": "Group the Maven test dependencies (junit-jupiter, gson); the runtime library is dependency-free.",
      "matchManagers": ["maven"],
      "matchDepTypes": ["test"],
      "groupName": "maven test dependencies"
    },
    {
      "description": "Devcontainer base image (.devcontainer/Dockerfile -> ubuntu).",
      "matchManagers": ["dockerfile"],
      "groupName": "devcontainer image"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the pinned Temurin JDK major (ARG JAVA_VERSION) in the devcontainer Dockerfile.",
      "managerFilePatterns": ["/(^|/)\\.devcontainer/Dockerfile$/"],
      "matchStrings": ["ARG JAVA_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "java",
      "datasourceTemplate": "java-version"
    }
  ]
}
