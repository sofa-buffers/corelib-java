{
  "name": "Java",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "vscode",
  // Load local secrets (GitHub token, etc.) from .devcontainer/.env.
  // Copy .env.example to .env first; the real .env is gitignored.
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.devcontainer/.env"],
  "customizations": {
    "vscode": {
      "extensions": ["vscjava.vscode-java-pack", "vscjava.vscode-gradle", "anthropic.claude-code"]
    }
  }
}
